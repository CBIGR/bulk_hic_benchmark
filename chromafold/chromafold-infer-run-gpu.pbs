#!/usr/bin/env bash

#PBS -l nodes=1:ppn=quarter:gpus=1
#PBS -l walltime=60:00:00
#PBS -l mem=64gb

module load Single-cell-python-bundle/2024.02-foss-2023a
ml unload PyTorch/2.1.2-foss-2023a  
ml load  PyTorch/2.1.2-foss-2023a-CUDA-12.1.1
ml load h5py/3.9.0-foss-2023a

cd /scratch/gent/vo/000/gvo00027/projects/CBIGR/24NHT_master_thesis/code/chromafold/ChromaFold/chromafold

for dataset in IMR90 H1 K562; do
    datapath="/scratch/gent/vo/000/gvo00027/projects/CBIGR/24NHT_master_thesis/code/chromafold/chromafold-dataset/${dataset}/processed_input"
    savepath="/scratch/gent/vo/000/gvo00027/projects/CBIGR/24NHT_master_thesis/code/chromafold/output/${dataset}"
    modelpath="/scratch/gent/vo/000/gvo00027/projects/CBIGR/24NHT_master_thesis/code/chromafold/models/chromafold_CTCFmotif.pth.tar"
    for chr in {1..22}; do
        python inference.py --data-path $datapath -ct $dataset --model-path $modelpath -chrom $chr -offset 1000000 --genome hg38 --save-path $savepath
    done
done
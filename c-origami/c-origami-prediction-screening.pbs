#!/usr/bin/env bash

#PBS -l nodes=1:ppn=8
#PBS -l walltime=02:00:00
#PBS -l mem=8gb

module load Single-cell-python-bundle/2024.02-foss-2023a
module load torchvision/0.16.0-foss-2023a
module load pyBigWig/0.3.22-gfbf-2023a

cd /scratch/gent/vo/000/gvo00027/projects/CBIGR/24NHT_master_thesis/code/c-origami/c-origami/src

python corigami/inference/screening.py \
    --chr "chr2" \
    --celltype "imr90" \
    --model "/scratch/gent/vo/000/gvo00027/projects/CBIGR/24NHT_master_thesis/code/c-origami/corigami-dataset/corigami_data/model_weights/corigami_base.ckpt" \
    --seq "/scratch/gent/vo/000/gvo00027/projects/CBIGR/24NHT_master_thesis/code/c-origami/corigami-dataset/corigami_data/data/hg38/dna_sequence" \
    --ctcf "/scratch/gent/vo/000/gvo00027/projects/CBIGR/24NHT_master_thesis/code/c-origami/corigami-dataset/corigami_data/data/hg38/imr90/genomic_features/ctcf_log2fc.bw" \
    --atac "/scratch/gent/vo/000/gvo00027/projects/CBIGR/24NHT_master_thesis/code/c-origami/corigami-dataset/corigami_data/data/hg38/imr90/genomic_features/atac.bw" \
    --screen-start 1250000 \
    --screen-end 2250000 \
    --perturb-width 1000 \
    --step-size 1000 \
    --plot-impact-score \
    --save-pred --save-perturbation --save-diff --save-bedgraph







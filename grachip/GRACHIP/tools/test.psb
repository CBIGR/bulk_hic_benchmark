# ml load OpenNMT-py/3.5.1-foss-2023a-CUDA-12.1.1 
ml load Rust/1.70.0-GCCcore-12.3.0  
ml load pybedtools/0.9.1-foss-2023a 
ml load HF-Datasets/2.18.0-gfbf-2023a 

cd "/scratch/gent/vo/000/gvo00027/projects/CBIGR/24NHT_master_thesis/code/grachip/GRACHIP/tools"
python DNA_encoder.py \
    --model_type "dna" \
    --tokenizer_name "dna6" \
    --model_name_or_path "/scratch/gent/vo/000/gvo00027/projects/CBIGR/24NHT_master_thesis/code/grachip/GRACHIP/data/6-new-12w-0" \
    --task_name "dnaprom" \
    --do_predict \
    --data_dir "/scratch/gent/vo/000/gvo00027/projects/CBIGR/24NHT_master_thesis/code/grachip/GRACHIP/output_test" \
    --max_seq_length "75" \
    --per_gpu_pred_batch_size "128" \
    --output_dir  "/scratch/gent/vo/000/gvo00027/projects/CBIGR/24NHT_master_thesis/code/grachip/GRACHIP/data/6-new-12w-0" \
    --predict_dir "/scratch/gent/vo/000/gvo00027/projects/CBIGR/24NHT_master_thesis/code/grachip/GRACHIP/output_test/output.npy" \
    --n_process "2"
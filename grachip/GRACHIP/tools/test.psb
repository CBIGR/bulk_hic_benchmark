module load Single-cell-python-bundle/2024.02-foss-2023a
module load torchvision/0.16.0-foss-2023a
module load pyBigWig/0.3.22-gfbf-2023a
module load pyfaidx/0.8.1.1-GCCcore-12.3.0 

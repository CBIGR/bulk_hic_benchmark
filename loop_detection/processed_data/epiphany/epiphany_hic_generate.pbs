#!/usr/bin/env bash

#PBS -l nodes=1:ppn=12
#PBS -l walltime=48:00:00
#PBS -l mem=32gb

module load Single-cell-python-bundle/2024.02-foss-2023a

modelname="epiphany"
cd /scratch/gent/vo/000/gvo00027/projects/CBIGR/24NHT_master_thesis/code/loop_detection/processed_data/epiphany

for dataset in GM12878 IMR90 K562 H1; do
    path="/scratch/gent/vo/000/gvo00027/projects/CBIGR/24NHT_master_thesis/code/epiphany/output/whole/${dataset}"
    bedpe_path_save="/scratch/gent/vo/000/gvo00027/projects/CBIGR/24NHT_master_thesis/code/loop_detection/processed_data/output/${modelname}/bedpe"
    python bedpe_norm.py --path $path --dataset $dataset --bedpe_path_save $bedpe_path_save
done

chr_size="/scratch/gent/vo/000/gvo00027/projects/CBIGR/24NHT_master_thesis/code/loop_detection/processed_data/hg38.chrom.sizes"
for dataset in GM12878 H1 IMR90 K562; do
    path="/scratch/gent/vo/000/gvo00027/projects/CBIGR/24NHT_master_thesis/code/loop_detection/processed_data/output/${modelname}/bedpe/${dataset}_10000_norm.bedpe"
    output="/scratch/gent/vo/000/gvo00027/projects/CBIGR/24NHT_master_thesis/code/loop_detection/processed_data/output/${modelname}/hic/${modelname}_${dataset}_norm.hic"
    java -jar /scratch/gent/vo/000/gvo00027/projects/CBIGR/24NHT_master_thesis/code/loop_detection/processed_data/juicer_tools_1.22.01.jar pre -d -r 10000 -k KR -v ${path} ${output} ${chr_size}
    
    path_count="/scratch/gent/vo/000/gvo00027/projects/CBIGR/24NHT_master_thesis/code/loop_detection/processed_data/output/${modelname}/bedpe/${dataset}_10000_count.bedpe"
    output_count="/scratch/gent/vo/000/gvo00027/projects/CBIGR/24NHT_master_thesis/code/loop_detection/processed_data/output/${modelname}/hic/${modelname}_${dataset}_count.hic"
    java -jar /scratch/gent/vo/000/gvo00027/projects/CBIGR/24NHT_master_thesis/code/loop_detection/processed_data/juicer_tools_1.22.01.jar pre -d -r 10000 -k KR -v ${path_count} ${output_count} ${chr_size}
done
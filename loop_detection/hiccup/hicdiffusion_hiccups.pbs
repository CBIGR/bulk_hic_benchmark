#!/usr/bin/env bash

#PBS -l nodes=1:ppn=quarter:gpus=1
#PBS -l walltime=12:00:00
#PBS -l mem=64gb

ml load accelerate/0.33.0-foss-2023a-CUDA-12.1.1  
cd /scratch/gent/vo/000/gvo00027/projects/CBIGR/24NHT_master_thesis/code/loop_detection/hiccup

model_name="hicdiffusion"
resolution=8192

path="/scratch/gent/vo/000/gvo00027/projects/CBIGR/24NHT_master_thesis/code/loop_detection/processed_data/output/${model_name}/hic/${model_name}_hg38_count.hic"
output="/scratch/gent/vo/000/gvo00027/projects/CBIGR/24NHT_master_thesis/code/loop_detection/hiccup/output/${model_name}/count"
java -jar juicer_tools_1.22.01.jar hiccups -k KR -r $resolution -f 0.1 -t 1.5 -p 2 -i 5 -d 20000 $path $output

path_norm="/scratch/gent/vo/000/gvo00027/projects/CBIGR/24NHT_master_thesis/code/loop_detection/processed_data/output/${model_name}/hic/${model_name}_hg38_norm.hic"
output_norm="/scratch/gent/vo/000/gvo00027/projects/CBIGR/24NHT_master_thesis/code/loop_detection/hiccup/output/${model_name}/norm"
java -jar juicer_tools_1.22.01.jar hiccups -k KR -r $resolution -f 0.1 -t 1.5 -p 2 -i 5 -d 20000 ${path_norm} ${output_norm}
